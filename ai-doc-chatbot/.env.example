# Choose ONE provider
GROQ_API_KEY=gsk_...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIza...

# Which LLM provider to use: groq | openai | gemini
LLM_PROVIDER=groq

# Model names
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-1.5-flash

# App settings
FLASK_SECRET_KEY=change-me-to-something-random
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH_MB=20
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=4
